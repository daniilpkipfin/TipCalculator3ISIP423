<Window x:Class="TipCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Калькулятор чаевых" Height="480" Width="420"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen">

    <!-- Основной контейнер с отступами -->
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="Auto"/>
            <!-- Сумма счёта -->
            <RowDefinition Height="Auto"/>
            <!-- Количество гостей -->
            <RowDefinition Height="Auto"/>
            <!-- Процент чаевых -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопка -->
            <RowDefinition Height="*"/>
            <!-- Результаты -->
        </Grid.RowDefinitions>

        <!-- Заголовок приложения -->
        <TextBlock Grid.Row="0"
                   Text="Калькулятор чаевых"
                   FontSize="22"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <!-- Поле ввода суммы счёта -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Сумма счёта (руб.):" FontSize="14" Margin="0,0,0,4"/>
            <!-- x:Name используется в Code-Behind для получения значения -->
            <TextBox x:Name="txtBillAmount"
                     FontSize="14"
                     Height="32"
                     Padding="6,4"
                     ToolTip="Введите сумму счёта, например: 1500"/>
        </StackPanel>

        <!-- Поле ввода количества гостей -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Количество гостей:" FontSize="14" Margin="0,0,0,4"/>
            <!-- По умолчанию 1 гость -->
            <TextBox x:Name="txtGuestCount"
                     Text="1"
                     FontSize="14"
                     Height="32"
                     Padding="6,4"
                     ToolTip="Введите количество гостей (целое число от 1)"/>
        </StackPanel>

        <!-- Выбор процента чаевых через RadioButton -->
        <GroupBox Grid.Row="3"
                  Header="Процент чаевых"
                  FontSize="14"
                  Margin="0,0,0,16"
                  Padding="10,6">
            <StackPanel>
                <!-- Каждый RadioButton соответствует одному варианту чаевых -->
                <RadioButton x:Name="rbNoTip"
                             Content="Без чаевых (0%)"
                             IsChecked="True"
                             FontSize="13"
                             Margin="0,4"/>
                <RadioButton x:Name="rbTip5"
                             Content="5%"
                             FontSize="13"
                             Margin="0,4"/>
                <RadioButton x:Name="rbTip10"
                             Content="10%"
                             FontSize="13"
                             Margin="0,4"/>
                <RadioButton x:Name="rbTip15"
                             Content="15%"
                             FontSize="13"
                             Margin="0,4"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопка запуска расчёта -->
        <Button Grid.Row="4"
                x:Name="btnCalculate"
                Content="Рассчитать"
                FontSize="15"
                FontWeight="SemiBold"
                Height="40"
                Background="#2196F3"
                Foreground="White"
                BorderThickness="0"
                Cursor="Hand"
                Click="btnCalculate_Click"
                Margin="0,0,0,16"/>

        <!-- Блок с результатами (изначально скрыт) -->
        <Border Grid.Row="5"
                x:Name="resultPanel"
                Visibility="Collapsed"
                Background="#F1F8E9"
                BorderBrush="#8BC34A"
                BorderThickness="1.5"
                CornerRadius="6"
                Padding="14">
            <StackPanel>
                <TextBlock Text="Результат:" FontSize="14" FontWeight="Bold" Margin="0,0,0,8"/>

                <!-- Строка: сумма счёта -->
                <DockPanel Margin="0,2">
                    <TextBlock Text="Сумма счёта:" FontSize="13" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="lblBill" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Строка: чаевые -->
                <DockPanel Margin="0,2">
                    <TextBlock Text="Чаевые:" FontSize="13" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="lblTip" FontSize="13" FontWeight="SemiBold"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Строка: итого -->
                <DockPanel Margin="0,2">
                    <TextBlock Text="Итого:" FontSize="13" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="lblTotal" FontSize="13" FontWeight="Bold"
                               Foreground="#388E3C"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- Разделитель — показывается только при > 1 гостя -->
                <Separator x:Name="sepGuests" Margin="0,6" Visibility="Collapsed"/>

                <!-- Строка: количество гостей — только при > 1 -->
                <DockPanel x:Name="pnlPerPerson" Margin="0,2" Visibility="Collapsed">
                    <TextBlock x:Name="lblPerPersonLabel" FontSize="13" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="lblPerPerson" FontSize="13" FontWeight="Bold"
                               Foreground="#1565C0"
                               HorizontalAlignment="Right"/>
                </DockPanel>
            </StackPanel>
        </Border>

    </Grid>
</Window>
